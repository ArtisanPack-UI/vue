{
  "name": "@artisanpack-ui/vue-laravel",
  "version": "0.0.0",
  "description": "Inertia.js adapter wrappers for ArtisanPack UI Vue components",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && vue-tsc --project tsconfig.build.json",
    "type-check": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@artisanpack-ui/vue": "*",
    "@artisanpack-ui/tokens": "*"
  },
  "devDependencies": {
    "@inertiajs/vue3": "^2.0.0",
    "@testing-library/vue": "^8.1.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "esbuild-plugin-vue3": "^0.4.2",
    "jsdom": "^27.0.1",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "vue": "^3.5.0"
  },
  "peerDependencies": {
    "@inertiajs/vue3": "^2.0.0",
    "vue": "^3.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
