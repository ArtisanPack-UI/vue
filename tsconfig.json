{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@artisanpack-ui/vue": ["./packages/vue/src"],
      "@artisanpack-ui/vue-laravel": ["./packages/vue-laravel/src"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
