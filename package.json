{
  "name": "@artisanpack-ui/vue-monorepo",
  "private": true,
  "workspaces": [
    "packages/vue",
    "packages/vue-laravel"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "eslint packages/*/src --ext .ts,.vue",
    "format": "prettier --write \"packages/*/src/**/*.{ts,vue}\""
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
